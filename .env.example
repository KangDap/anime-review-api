# App
APP_PORT=3000
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=24h

# PostgreSQL (container)
POSTGRES_DB=anime_review
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-password

# App connection string inside Docker network
APP_DATABASE_URL=postgresql://postgres:replace-with-strong-password@db:5432/anime_review?schema=public

# Optional host DB port mapping for local development compose
DB_PORT=5433
